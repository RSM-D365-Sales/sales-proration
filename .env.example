# Secrets for the D365 connection. Copy to `.env` (gitignored).
#
# Only CLIENT SECRETS belong here now. Everything else (base URL, tenant/client
# id, service names) is managed per-environment on the in-app Setup page
# (/setup.html) and stored in server/data/environments.json.
#
# Each environment profile names the .env variable that holds its secret, so you
# can keep one secret per environment and toggle between them on the Setup page.
# Real OS environment variables override anything set here.

# Default profile's secret (profile field "Secret .env variable" = D365_CLIENT_SECRET).
D365_CLIENT_SECRET=

# Example of per-environment secrets — name these whatever you like and point
# each profile's "Secret .env variable" field at the matching name:
# D365_CLIENT_SECRET_DEV=
# D365_CLIENT_SECRET_PROD=

# --- optional: first-run seed -------------------------------------------------
# If server/data/environments.json does not exist yet and you set D365_BASE_URL
# here, a starter "Default" profile is created from these values on first boot.
# After that, manage everything from the Setup page.
# D365_BASE_URL=
# D365_TENANT_ID=
# D365_CLIENT_ID=
# D365_SERVICE_GROUP=RSMProrationReadSvcGrp
